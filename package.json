{
  "name": "shhheth",
  "version": "0.0.1",
  "private": true,
  "description": "Live counter of all ETH ever shielded in Ethereum privacy protocols",
  "scripts": {
    "dev": "pnpm --filter web dev",
    "build": "pnpm --filter web build",
    "subgraph:codegen": "pnpm --filter \"subgraph-*\" codegen",
    "subgraph:build": "pnpm --filter \"subgraph-*\" build",
    "subgraph:deploy:aztec": "pnpm --filter subgraph-aztec deploy",
    "subgraph:deploy:tornado": "pnpm --filter subgraph-tornado deploy",
    "subgraph:deploy:tornado-flow": "pnpm --filter subgraph-tornado deploy:flow",
    "subgraph:deploy:railgun": "pnpm --filter subgraph-railgun deploy",
    "subgraph:deploy:0xbow": "pnpm --filter subgraph-0xbow deploy"
  },
  "packageManager": "pnpm@10.17.1"
}
